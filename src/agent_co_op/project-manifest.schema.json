{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lwgerhardt/agent-co-op-mcp/project-manifest.schema.json",
  "title": "agent-co-op project manifest",
  "type": "object",
  "required": ["id"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "repository": {
      "type": "string"
    },
    "roles": {
      "type": "object",
      "propertyNames": {
        "enum": [
          "scaffold",
          "planner",
          "verifier",
          "efficiency",
          "resume"
        ]
      },
      "additionalProperties": {
        "$ref": "#/$defs/roleConfig"
      }
    },
    "verification": {
      "$ref": "#/$defs/verificationConfig"
    }
  },
  "$defs": {
    "roleConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "notes": {
          "type": "string"
        },
        "agent": {
          "type": "string",
          "minLength": 1
        },
        "model_tier": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "work_mode": {
          "type": "string",
          "enum": ["background", "think", "longContext", "default"]
        }
      }
    },
    "verificationCommand": {
      "type": "object",
      "required": ["id", "label", "command"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "timeout": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "verificationProfile": {
      "type": "object",
      "required": ["commands"],
      "additionalProperties": false,
      "properties": {
        "expected_branch": {
          "type": "string"
        },
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/verificationCommand"
          }
        },
        "manual_checks": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "verificationConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "profiles": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/$defs/verificationProfile"
          }
        }
      }
    }
  }
}
