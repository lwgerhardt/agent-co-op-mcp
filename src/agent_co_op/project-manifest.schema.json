{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lwgerhardt/agent-co-op-mcp/project-manifest.schema.json",
  "title": "agent-co-op project manifest",
  "type": "object",
  "required": ["id"],
  "additionalProperties": false,
  "patternProperties": {
    "^x-": {}
  },
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string"
    },
    "title": {
      "type": "string",
      "description": "Optional display title (alias for name in consumer repos)"
    },
    "description": {
      "type": "string"
    },
    "repository": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["planned", "active", "paused", "archived"]
    },
    "branch": {
      "type": "string",
      "minLength": 1
    },
    "handoff_doc": {
      "type": "string",
      "minLength": 1
    },
    "plan_doc": {
      "type": "string"
    },
    "verification_profile": {
      "type": "string",
      "minLength": 1,
      "description": "Profile id referencing a consumer-repo verification profile JSON file"
    },
    "domains": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "bootstrap": {
      "$ref": "#/$defs/bootstrapCommands"
    },
    "status_cmd": {
      "type": "string",
      "minLength": 1
    },
    "paths_index": {
      "type": "string",
      "minLength": 1
    },
    "read_map": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "$ref": "#/$defs/readMapEntry"
          }
        ]
      }
    },
    "planner_notes": {
      "type": "string"
    },
    "verifier_notes": {
      "type": "string"
    },
    "roles": {
      "type": "object",
      "propertyNames": {
        "enum": [
          "scaffold",
          "planner",
          "verifier",
          "efficiency",
          "resume"
        ]
      },
      "additionalProperties": {
        "$ref": "#/$defs/roleConfig"
      }
    },
    "verification": {
      "$ref": "#/$defs/verificationConfig"
    }
  },
  "$defs": {
    "bootstrapCommands": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        }
      ]
    },
    "readMapEntry": {
      "type": "object",
      "required": ["file"],
      "additionalProperties": false,
      "properties": {
        "file": {
          "type": "string",
          "minLength": 1
        },
        "lines": {
          "type": "string"
        },
        "why": {
          "type": "string"
        }
      }
    },
    "roleConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "notes": {
          "type": "string"
        },
        "agent": {
          "type": "string",
          "minLength": 1
        },
        "model_tier": {
          "type": "string",
          "enum": ["low", "medium", "high", "fast", "capable"]
        },
        "work_mode": {
          "type": "string",
          "enum": ["background", "think", "longContext", "default"]
        }
      }
    },
    "verificationCommand": {
      "type": "object",
      "required": ["id", "label", "command"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "timeout": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "verificationProfile": {
      "type": "object",
      "required": ["commands"],
      "additionalProperties": false,
      "properties": {
        "expected_branch": {
          "type": "string"
        },
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/verificationCommand"
          }
        },
        "manual_checks": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "verificationConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "profiles": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "$ref": "#/$defs/verificationProfile"
          }
        }
      }
    }
  }
}
