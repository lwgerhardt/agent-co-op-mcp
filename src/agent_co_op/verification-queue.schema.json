{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lwgerhardt/agent-co-op-mcp/verification-queue.schema.json",
  "title": "agent-co-op verification queue",
  "type": "object",
  "required": ["version", "profile_id", "commands"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "profile_id": {
      "type": "string",
      "minLength": 1
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "expected_branch": {
      "type": "string"
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/command"
      }
    },
    "manual_checks": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "command": {
      "type": "object",
      "required": ["id", "label", "command"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "timeout": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
